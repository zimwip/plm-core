# ============================================================
# PLM Core - Variables d'environnement
# Copier ce fichier en .env et adapter les valeurs
# NE PAS committer .env en production
# ============================================================

# PostgreSQL — required, no default
# Generate: openssl rand -base64 32
PG_PASSWORD=

# Inter-service shared secret — required, no default.
# Used as HMAC-SHA256 key for JWT signing (spe-api mints, psm/pno verify)
# AND as X-Service-Secret for registry calls and pno /users/{id}/context.
# MUST be >= 32 bytes (HS256 requirement).
# Generate: openssl rand -base64 32
PLM_SERVICE_SECRET=

# Optionnel : port applicatif (défaut 8080)
# PLM_PORT=8080
