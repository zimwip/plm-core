# ----------------------------------------------------------------------------
# Apache Maven Wrapper startup batch script, version 3.3.2
# ----------------------------------------------------------------------------

# If JAVA_HOME is set, use it; otherwise try to find java in PATH
if [ -n "$JAVA_HOME" ]; then
    JAVA_CMD="$JAVA_HOME/bin/java"
elif command -v java >/dev/null 2>&1; then
    JAVA_CMD="java"
else
    echo "Error: JAVA_HOME is not set and 'java' was not found in PATH." >&2
    exit 1
fi

# Locate the script
MAVEN_PROJECTBASEDIR="${MAVEN_BASEDIR:-}"
if [ -z "$MAVEN_PROJECTBASEDIR" ]; then
    MAVEN_PROJECTBASEDIR=$(cd "$(dirname "$0")" && pwd)
fi

MAVEN_WRAPPER_PROPERTIES="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties"

# Read properties
if [ -f "$MAVEN_WRAPPER_PROPERTIES" ]; then
    DISTRIBUTION_URL=$(grep '^distributionUrl=' "$MAVEN_WRAPPER_PROPERTIES" | sed 's/distributionUrl=//')
    WRAPPER_VERSION=$(grep '^wrapperVersion=' "$MAVEN_WRAPPER_PROPERTIES" | sed 's/wrapperVersion=//')
fi

if [ -z "$DISTRIBUTION_URL" ]; then
    echo "Error: distributionUrl not found in $MAVEN_WRAPPER_PROPERTIES" >&2
    exit 1
fi

# Determine distribution directory
DIST_FILENAME=$(basename "$DISTRIBUTION_URL")
DIST_NAME="${DIST_FILENAME%.zip}"
MAVEN_USER_HOME="${MAVEN_USER_HOME:-$HOME/.m2}"
MAVEN_WRAPPER_CACHE="$MAVEN_USER_HOME/wrapper/dists"
DIST_DIR="$MAVEN_WRAPPER_CACHE/$DIST_NAME"
MAVEN_HOME="$DIST_DIR/$(ls "$DIST_DIR" 2>/dev/null | head -1)"

# Download and unzip Maven if not already cached
if [ ! -x "$MAVEN_HOME/bin/mvn" ]; then
    mkdir -p "$DIST_DIR"
    DOWNLOAD_DEST="$DIST_DIR/$DIST_FILENAME"
    echo "Downloading Maven from $DISTRIBUTION_URL ..."

    if command -v curl >/dev/null 2>&1; then
        curl -fsSL -o "$DOWNLOAD_DEST" "$DISTRIBUTION_URL" || {
            echo "Error: Download failed." >&2; exit 1
        }
    elif command -v wget >/dev/null 2>&1; then
        wget -q -O "$DOWNLOAD_DEST" "$DISTRIBUTION_URL" || {
            echo "Error: Download failed." >&2; exit 1
        }
    else
        echo "Error: Neither curl nor wget found. Cannot download Maven." >&2
        exit 1
    fi

    unzip -q "$DOWNLOAD_DEST" -d "$DIST_DIR"
    rm -f "$DOWNLOAD_DEST"
    MAVEN_HOME="$DIST_DIR/$(ls "$DIST_DIR" | head -1)"
    echo "Maven installed at $MAVEN_HOME"
fi

exec "$MAVEN_HOME/bin/mvn" "$@"
